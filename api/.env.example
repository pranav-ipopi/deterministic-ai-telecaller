# Copy to .env and fill in.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxx
LIVEKIT_API_SECRET=secretxxx

# Generate both with: openssl rand -hex 32
SHARED_API_KEY=replace-me-32-bytes-hex     # ALR sends this in X-API-Key
AGENT_API_KEY=replace-me-32-bytes-hex      # agent sends this to ALR callback

OUTBOUND_AGENT=outbound-caller
INBOUND_AGENT=inbound-caller
DB_PATH=/data/tenants.db

# ─── Admin UI ──────────────────────────────────────────────────────────
# Single password for the /admin web UI. Choose something long & random.
ADMIN_PASSWORD=replace-with-a-long-passphrase
# Used to sign session cookies. Generate: openssl rand -hex 32
ADMIN_COOKIE_SECRET=replace-with-32-bytes-hex

# Required for auto-sync of inbound SIP dispatch rules when you save a tenant.
# Get this ID from `lk sip inbound-trunk list` after creating the trunk.
SIP_INBOUND_TRUNK_ID=ST_inbound_xxx
